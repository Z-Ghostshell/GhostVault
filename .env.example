# GhostVault — copy to .env and adjust (`.env` is gitignored).
# With direnv: `cp .env.example .env` then `direnv allow` in this directory.

# ── OpenAI-compatible API (embeddings + chat completions) ──
# Both are supported: gvsvd calls {OPENAI_BASE_URL}/embeddings and .../chat/completions
# with OPENAI_API_KEY as Bearer. Point BASE_URL at api.openai.com, Azure OpenAI proxies,
# or an internal router (e.g. https://llm-router.example.com/v1 — include /v1).
OPENAI_API_KEY=
# OpenAI-compatible API root (include /v1 for api.openai.com). Embeddings: POST {OPENAI_BASE_URL}/embeddings
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional only if embeddings are not at {OPENAI_BASE_URL}/embeddings
# OPENAI_EMBEDDINGS_URL=

# ── Postgres (gvsvd process). Docker Compose sets this inside the ghostvault container. ──
# Local gvsvd against compose DB on host:
# DATABASE_URL=postgres://ghostvault:ghostvault@localhost:5432/ghostvault?sslmode=disable

# ── Server ──
# gvsvd listen address inside the container (always include the port, e.g. :8080).
# GV_HTTP_ADDR=:8080
# Published host port for the **edge** nginx (single entry: /api /mcp-<token> /dashboard). Default 8989.
# EDGE_HOST_PORT=8989

# ── Edge nginx: secret path segment for /mcp-<token>/ (REQUIRED to boot edge) ──
# The edge proxies MCP only at /mcp-${GV_MCP_PATH_TOKEN}/ so that public HTTPS exposure
# (Tailscale Funnel, Cloudflare Tunnel, etc.) cannot hit gvmcp without the token. Bare /mcp/
# returns 404. Generate with: `openssl rand -hex 32`. Rotate: edit this value, then
# `docker compose up -d --force-recreate edge` and update Claude's custom connector URL.
# GV_MCP_PATH_TOKEN=

# ── Encryption mode: `on` | `off` — MUST match existing vault row after first init; immutable per DB ──
GV_ENCRYPTION=on

# ── Auth mode ──
# Set once at `gvctl init -auth-mode …` (stored in the vault row, immutable thereafter):
#   session      — today's interactive unlock flow; RAM-only sessions, clients re-unlock on restart.
#   auto_unlock  — server holds the password (see GHOSTVAULT_PASSWORD_FILE below) and unwraps
#                  the DEK at boot; sessions persist across gvsvd restart. Reuse bearers indefinitely.
#   api_keys     — per-client DEK-wrapping credentials (roadmap; see docs/future/API-KEYS.md).
# The chosen mode is read back via `GET /v1/vault`. To change modes you must re-init the vault.
#
# Required ONLY when the stored vault row has auth_mode=auto_unlock AND GV_ENCRYPTION=on.
# Prefer a file mount with 0400 perms; the env-var fallback logs a warning.
# GHOSTVAULT_PASSWORD_FILE=/run/secrets/ghostvault_password
# GHOSTVAULT_PASSWORD=

# ── Sessions (unlock token lifetime) ──
# Interactive `auth_mode=session` defaults (idle=1h, max=12h).
# GV_SESSION_IDLE_MINUTES=60
# GV_SESSION_MAX_HOURS=12
# For `auth_mode=auto_unlock`, sessions persist across restart — tune much longer so clients
# don't need rotation, and rely on `gvctl lock` / `make rotate-token` for revocation:
#   GV_SESSION_IDLE_MINUTES=43200   # 30 days
#   GV_SESSION_MAX_HOURS=2160       # 90 days

# ── Runtime tuning (algorithm, retrieval, infer, body limit, access log, etc.) ──
# Editable YAML in the repo: configs/gvsvd.yaml. Optional hot overrides in Postgres; dashboard **Config** and
# GET/PATCH/POST /v1/tuning. Process startup + SIGHUP + POST /v1/tuning/reload re-merge file + DB.
# GV_Tuning_FILE=configs/gvsvd.yaml
# (Docker image embeds a copy at /etc/ghostvault/gvsvd.yaml; compose mounts the repo file over it.)

#
# Auth diagnostics on failed vault routes (ingest/retrieve/…): logs masked bearer fingerprint + token shape.
# Compose defaults GV_DEBUG_AUTH=false; set true when troubleshooting auth.
# GV_DEBUG_AUTH=true
# Log the complete bearer/session token (unsafe). Only with GV_DEBUG_AUTH=true.
# GV_DEBUG_AUTH_FULL=true
# gvmcp→gvsvd 401 diagnostics (compose defaults false); set GHOSTVAULT_DEBUG_AUTH=true to enable.
# GHOSTVAULT_DEBUG_AUTH=true

# ── Local MCP / gvctl (not read by gvsvd) ──
# gvsvd URL for gvctl / OpenAPI servers.url / `make dashboard-dev` Vite proxy when calling through **edge**
# (paths: /api → gvsvd, /mcp → gvmcp). Use origin + /api — no trailing slash.
# GHOSTVAULT_BASE_URL=http://127.0.0.1:8989/api
#
# ── gvmcp in Docker: `make up` starts it (no separate host port; use http://127.0.0.1:8989/mcp/ through edge).
# Compose mounts `./.ghostvault-bearer` into the container (see docker-compose.yml). Run `make refresh-token` after gvsvd restarts so that file has a session token, or set GHOSTVAULT_BEARER_TOKEN in `.env` instead (non-empty env overrides the file).
# Remote MCP (Claude Desktop `mcp-remote` → https://…/mcp/): set these in `.env` so the **gvmcp** container has a valid session and defaults (not in Desktop):
#   GHOSTVAULT_BEARER_TOKEN=<gvctl unlock -token-only against http://127.0.0.1:8989/api>
#   GHOSTVAULT_DEFAULT_VAULT_ID=<uuid from unlock>
#   GHOSTVAULT_DEFAULT_USER_ID=default   # optional scope label
# Re-unlock and refresh after gvsvd restart. HTTPS to your tailnet hostname requires Tailscale Serve/Funnel → :8989 (see docs/deploy.md).
#
# Optional: OAuth on streamable MCP (Claude custom connector — RFC 9728 + RFC 7662 introspection).
# Requires your own authorization server (Auth0, Keycloak, ZITADEL, …). See docs/integration/Claude-mcp.md § OAuth 2.0.
# When GHOSTVAULT_OAUTH_INTROSPECTION_URL is set, gvmcp validates Claude's Bearer token before MCP; you still
# need GHOSTVAULT_TOKEN_FILE for gvmcp → gvsvd. Public URLs must match your Funnel/tunnel host.
#
# claude.ai currently ignores the RFC 9728 authorization_servers field and instead builds /authorize,
# /token, /register and /.well-known/oauth-authorization-server on the MCP host itself
# (anthropics/claude-ai-mcp#82). gvmcp serves a thin facade on those paths that 302s / proxies to
# the upstream IdP defined below. `audience` is injected into /authorize and /token (Auth0-style binding).
# GHOSTVAULT_OAUTH_INTROSPECTION_URL=
# GHOSTVAULT_OAUTH_AUTH_SERVER_ISSUER=
# GHOSTVAULT_OAUTH_RESOURCE=https://YOUR-HOST/mcp-<GV_MCP_PATH_TOKEN>/
# GHOSTVAULT_OAUTH_METADATA_URL=https://YOUR-HOST/.well-known/oauth-protected-resource
# GHOSTVAULT_OAUTH_INTROSPECTION_CLIENT_ID=
# GHOSTVAULT_OAUTH_INTROSPECTION_CLIENT_SECRET=
# GHOSTVAULT_OAUTH_SCOPES=
# GHOSTVAULT_OAUTH_SCOPES_SUPPORTED=
# Audience (OAuth 2.0 `audience` parameter). Defaults to GHOSTVAULT_OAUTH_RESOURCE.
# GHOSTVAULT_OAUTH_AUDIENCE=https://YOUR-HOST/mcp-<GV_MCP_PATH_TOKEN>/
# Upstream AS URLs: if empty, gvmcp defaults to {issuer}authorize / oauth/token / oidc/register (Auth0 layout).
# ZITADEL (example): set issuer https://YOUR-ZITADEL-HOST and e.g.
#   GHOSTVAULT_OAUTH_UPSTREAM_AUTHORIZE_URL=https://YOUR-ZITADEL-HOST/oauth/v2/authorize
#   GHOSTVAULT_OAUTH_TOKEN_URL=https://YOUR-ZITADEL-HOST/oauth/v2/token
# GHOSTVAULT_OAUTH_UPSTREAM_AUTHORIZE_URL=
# GHOSTVAULT_OAUTH_TOKEN_URL=
# GHOSTVAULT_OAUTH_REGISTRATION_URL=
#
# Dashboard (Vite dev only) — optional seed for the browser after `gvctl unlock` (same string as .ghostvault-bearer).
# Restart `make dashboard-dev` after changing. Do not commit a real token. Prefer pasting into the dashboard UI instead.
# VITE_GHOSTVAULT_BEARER_TOKEN=
# When "true", production dashboard image builds show the "Retrieve debug" nav item (dev always can; use the on-page opt-out to hide). Docker: build-arg on dashboard/Dockerfile.
# VITE_SHOW_RETRIEVE_DEBUG=
# GHOSTVAULT_DEFAULT_VAULT_ID=
# GHOSTVAULT_DEFAULT_USER_ID=
# Passphrase for gvctl unlock when GV_ENCRYPTION=on (keep out of shell history if you prefer interactive unlock).
# GHOSTVAULT_PASSWORD=
# Optional: path for session token file (default .ghostvault-bearer). direnv loads it after dotenv.
# GHOSTVAULT_TOKEN_FILE=.ghostvault-bearer
# Do not put GHOSTVAULT_BEARER_TOKEN here. Session goes to hidden .ghostvault-bearer (gitignored):
#   make ctl && ./scripts/refresh-ghostvault-token.sh
# Or auto-mint when you cd into the repo (needs gvsvd running; GHOSTVAULT_PASSWORD above if encryption on).
# Auto-unlock only runs when .ghostvault-bearer is missing or empty — after gvsvd restart run: rm -f .ghostvault-bearer && cd .
# GHOSTVAULT_DIRENV_AUTO_UNLOCK=1
