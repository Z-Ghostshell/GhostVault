# GhostVault — direnv (see https://direnv.net)
# Pattern aligned with gis: load .env with direnv's parser (quotes, inline # comments).

if [[ -f .env ]]; then
  dotenv
fi

export GIT_ROOT
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

PATH_add "$(go env GOPATH 2>/dev/null)/bin"
PATH_add "bin"

# Hidden session file (gitignored). Not in .env — mint with: gvctl unlock -write-token-file .ghostvault-bearer
TOKEN_FILE="${GHOSTVAULT_TOKEN_FILE:-.ghostvault-bearer}"
if [[ "${TOKEN_FILE:0:1}" != "/" ]]; then
  TOKEN_FILE="$GIT_ROOT/$TOKEN_FILE"
fi

# Optional: mint token when file is missing (needs gvsvd up; GHOSTVAULT_PASSWORD in .env if GV_ENCRYPTION=on)
auto_unlock=0
case "${GHOSTVAULT_DIRENV_AUTO_UNLOCK:-}" in
  1 | true | TRUE | yes | YES | on | ON) auto_unlock=1 ;;
esac

if [[ "$auto_unlock" -eq 1 ]] && [[ ! -s "$TOKEN_FILE" ]] && [[ -n "${GHOSTVAULT_BASE_URL:-}" ]]; then
  need_pass=0
  case "${GV_ENCRYPTION:-on}" in
    on | true | TRUE | 1) need_pass=1 ;;
  esac
  if [[ "$need_pass" -eq 0 ]] || [[ -n "${GHOSTVAULT_PASSWORD:-}" ]]; then
    if [[ -x "$GIT_ROOT/bin/gvctl" ]]; then
      "$GIT_ROOT/bin/gvctl" unlock -write-token-file "$TOKEN_FILE" >/dev/null 2>&1 || true
    elif command -v go >/dev/null 2>&1; then
      (cd "$GIT_ROOT" && go run ./cmd/gvctl unlock -write-token-file "$TOKEN_FILE") >/dev/null 2>&1 || true
    fi
  fi
fi

if [[ -f "$TOKEN_FILE" ]] && [[ -s "$TOKEN_FILE" ]]; then
  _gv_bearer="$(tr -d '\n\r' < "$TOKEN_FILE")"
  export GHOSTVAULT_BEARER_TOKEN="$_gv_bearer"
  # Same string the dashboard seeds from VITE_GHOSTVAULT_BEARER_TOKEN (client bundle — dev/localhost only).
  export VITE_GHOSTVAULT_BEARER_TOKEN="$_gv_bearer"
  unset _gv_bearer
fi

REPO_NAME=$(basename "$GIT_ROOT" 2>/dev/null)

echo "GhostVault — ${REPO_NAME:-ghostvault} (direnv: dotenv if .env present)"
